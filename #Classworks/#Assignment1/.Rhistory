load("D:/R Practice/#Classworks/#Assignment1/air.RData")
library(skimr)
skim_without_charts(air)
qqnorm(air$PM10,
main= "Normal Q-Q plot for PM10 Concentration",
xlab= "Theoritical Quantities",
ylab= "Sample Quantities",
pch = 16,
col= "navyblue"
)
plot(air$NO2, air$PM10,
main = "Scatterplot of NO2 vs PM10 Concentrations",
xlab = "Nitrogen Dioxide (NO2) [ug/m3]",
ylab = "Particulate Matter (PM10) [ug/m3]",
pch = 16, col = "darkgreen"
)
cor(air$NO2, air$PM10)
set.seed(123)
B <- 2000
boot_cor <- numeric(B)
for(i in 1:B) {
sample_indices <- sample(1:nrow(air), replace = TRUE)
sample_data <- air[sample_indices, ]
boot_cor[i] <- cor(sample_data$NO2, sample_data$PM10)
}
se_boot <- sd(boot_cor)
round(se_boot, 4)
conf_interval <- quantile(boot_cor, probs = c(0.05, 0.95))
round(conf_interval, 4)
# Histogram
hist(boot_cor, breaks = 25, col = "lightblue",
main = "Bootstrap Distribution of Correlation Coefficient",
xlab = "Correlation Coefficient")
# Vertical lines for specific values
abline(v = 0.3993, col = "red", lwd = 2)                # Original Estimate (from Q3)
abline(v = mean(boot_cor), col = "blue", lty = 2, lwd = 2) # Bootstrap Mean
abline(v = conf_interval, col = "darkgreen", lty = 3, lwd = 2) # 90% CI Bounds
# Legend
legend("topright",
legend = c("Original Estimate", "Bootstrap Mean", "90% CI Bounds"),
col = c("red", "blue", "darkgreen"),
lty = c(1, 2, 3), lwd = 2, cex = 0.8)
tinytex::install_tinytex()
